# The n8n webhook URL the browser calls directly to generate a quiz from a
# file/text upload. Configure this in n8n's Webhook trigger node, then paste
# the "Production URL" here. Must have CORS enabled for this app's origin,
# and should use n8n's built-in header-auth or basic-auth option so random
# visitors can't trigger (and bill) your AI workflow.
VITE_N8N_QUIZ_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/generate-quiz

# Optional: if your n8n webhook is set up with Header Auth, set the expected
# header name/value here so the frontend can send it automatically.
VITE_N8N_WEBHOOK_AUTH_HEADER=x-webhook-token
VITE_N8N_WEBHOOK_AUTH_VALUE=replace_with_a_long_random_secret
